<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/rapidcmi5/db" VERSION="2026030200" COMMENT="Local RapidCMI5 tables"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd"
>
  <TABLES>
    <TABLE NAME="local_rapidcmi5_projects" COMMENT="RapidCMI5 projects tracking">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="name" TYPE="char" LENGTH="255" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="identifier" TYPE="char" LENGTH="255" NOTNULL="true" SEQUENCE="false" COMMENT="Stable project ID (courseId IRI from cmi5.xml)"/>
        <FIELD NAME="gitrepourl" TYPE="char" LENGTH="1333" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="description" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="currentversionid" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="currentpackageid" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="createdby" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="identifier_unique" UNIQUE="true" FIELDS="identifier"/>
      </INDEXES>
    </TABLE>

    <TABLE NAME="local_rapidcmi5_versions" COMMENT="Version history for RapidCMI5 projects">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="projectid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="versionnumber" TYPE="char" LENGTH="64" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="commithash" TYPE="char" LENGTH="64" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="buildtimestamp" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="packageid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="sha256hash" TYPE="char" LENGTH="64" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="releasenotes" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="createdby" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="projectid_fk" TYPE="foreign" FIELDS="projectid" REFTABLE="local_rapidcmi5_projects" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="projectid_versionnumber_unique" UNIQUE="true" FIELDS="projectid,versionnumber"/>
      </INDEXES>
    </TABLE>

    <TABLE NAME="local_rapidcmi5_deployments" COMMENT="Tracks cmi5 activity deployments from RapidCMI5 projects">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="projectid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="versionid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="cmid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="sectionid" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="projectid_fk" TYPE="foreign" FIELDS="projectid" REFTABLE="local_rapidcmi5_projects" REFFIELDS="id"/>
        <KEY NAME="versionid_fk" TYPE="foreign" FIELDS="versionid" REFTABLE="local_rapidcmi5_versions" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="projectid_courseid_unique" UNIQUE="true" FIELDS="projectid,courseid"/>
      </INDEXES>
    </TABLE>

    <TABLE NAME="local_rapidcmi5_player_versions" COMMENT="RapidCMI5 player runtime versions">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="version" TYPE="char" LENGTH="64" NOTNULL="true" SEQUENCE="false" COMMENT="Semver string (e.g. 0.7.0)"/>
        <FIELD NAME="sha256hash" TYPE="char" LENGTH="64" NOTNULL="false" SEQUENCE="false" COMMENT="ZIP content hash"/>
        <FIELD NAME="manifest" TYPE="text" NOTNULL="true" SEQUENCE="false" COMMENT="JSON: player file list and raw templates"/>
        <FIELD NAME="createdby" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="version_unique" UNIQUE="true" FIELDS="version"/>
      </INDEXES>
    </TABLE>
  </TABLES>
</XMLDB>
